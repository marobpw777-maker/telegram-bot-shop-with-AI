# =============================================================================
# .gitignore для Telegram Shop Bot «Solid Simple»
# Версия: 3.4 (Production Ready)
# =============================================================================

# -----------------------------------------------------------------------------
# СЕКРЕТЫ И КОНФИДЕНЦИАЛЬНЫЕ ФАЙЛЫ (НИКОГДА НЕ КОММИТИТЬ!)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# Личные секреты
*.secret
*.secrets
/secure_config/

# -----------------------------------------------------------------------------
# БАЗЫ ДАННЫХ (содержат данные клиентов!)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
shop.db
shop_database.db
agreements.db
bot_persistence
bot_persistence.pkl
bot/data/*.db
bot/data/*.sqlite

# MySQL relay
data/yookassa_queue/
yookassa_queue/

# -----------------------------------------------------------------------------
# ЛОГИ
# -----------------------------------------------------------------------------
*.log
logs/
bot.log
solid_simple.log
access.log*
webhook_debug.log
yookassa_webhook.log
yookassa_queue.log

# -----------------------------------------------------------------------------
# PYTHON артефакты
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/
.conda/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# ФОТО И МЕДИА (тяжёлые файлы)
# -----------------------------------------------------------------------------
bot/photos/*/
*.jpg
*.jpeg
*.png
*.webp
!bot/photos/.gitkeep
*.mp4
*.mp3
*.avi
*.mov
# НО grk.mp4 нужен боту — он не занимает много места
!bot/grk.mp4

# -----------------------------------------------------------------------------
# ВРЕМЕННЫЕ ФАЙЛЫ
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
bot/yookassa/
webhook/yookassa/full_notifications.log

# Системные
*.pid
*.lock
*.pem
*.key
*.crt
*.cer

# -----------------------------------------------------------------------------
# КРИТИЧЕСКИ ВАЖНО: перед коммитом проверьте:
# 1. Нет ли .env файлов с секретами
# 2. Нет ли логов с персональными данными
# 3. Нет ли баз данных с информацией о клиентах
# 4. Нет ли токенов и паролей в коде
# -----------------------------------------------------------------------------
