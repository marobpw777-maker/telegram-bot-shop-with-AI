# ===========================================
# ПРИМЕР ФАЙЛА .env для webhook (БЕЗОПАСНЫЙ ШАБЛОН)
# ===========================================
# Скопируйте этот файл в .env и заполните СВОИМИ значениями
# ⚠️ НЕ КОММИТЬТЕ .env В GIT!

# Токен для аутентификации webhook запросов (?token=...)
# Должен СОВПАДАТЬ с YOOKASSA_WEBHOOK_TOKEN в боте
YOOKASSA_WEBHOOK_TOKEN=generate_with_openssl_rand_base64_32

# Секрет для X-Forward-Secret заголовка
# Должен СОВПАДАТЬ с FORWARD_SECRET в боте
FORWARD_SECRET=generate_with_openssl_rand_hex_16

# Секретный ключ из кабинета ЮKassa
YOOKASSA_WEBHOOK_SECRET=live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Доступ к MySQL базе данных (одинаковый для бота и webhook)
YOOKASSA_RELAY_DB_HOST=localhost
YOOKASSA_RELAY_DB_USER=your_mysql_user
YOOKASSA_RELAY_DB_PASS=your_mysql_password
YOOKASSA_RELAY_DB_NAME=your_mysql_database

# Telegram бот (опционально — для уведомлений из webhook)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ADMIN_IDS=123456789,987654321
