# ===========================================
# ПРИМЕР ФАЙЛА .env (БЕЗОПАСНЫЙ ШАБЛОН)
# ===========================================
# Скопируйте этот файл в .env и заполните СВОИМИ значениями
# 
# ⚠️ ВАЖНО:
# 1. НЕ КОММИТЬТЕ .env В GIT!
# 2. Используйте сложные пароли (минимум 16 символов)
# 3. Регулярно ротируйте секреты (раз в 3-6 месяцев)
# 4. Ограничьте доступ к файлу: chmod 600 .env
#
# Для генерации секретов используйте:
# - openssl rand -base64 32  (для токенов)
# - openssl rand -hex 16     (для секретов)
# ===========================================

# ===========================================
# TELEGRAM BOT
# ===========================================
# Токен бота от @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ID админов (через запятую)
ADMIN_IDS=123456789,987654321

# ===========================================
# SHOP CONFIGURATION
# ===========================================
SHOP_NAME=Solid Simple
CURRENCY=RUB

# ===========================================
# TELEGRAM PAYMENTS
# ===========================================
# Provider token из Telegram (@BotFather или @ShopBot)
# ⚠️ Получите реальный токен, не используйте TEST в production!
PROVIDER_TOKEN=390540012:LIVE:XXXXXXXXXX

# ===========================================
# YOOKASSA PAYMENTS
# ===========================================
# Shop ID из личного кабинета ЮKassa
YOOKASSA_SHOP_ID=000000

# Secret Key из личного кабинета ЮKassa
# ⚠️ Начинается на "live_" или "test_"
YOOKASSA_SECRET_KEY=live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook токен для аутентификации (сгенерируйте случайную строку)
# Команда для генерации: openssl rand -base64 32
YOOKASSA_WEBHOOK_TOKEN=generate_this_with_openssl_rand_base64_32

# ===========================================
# WEBHOOK RELAY CONFIGURATION
# ===========================================
# Эти значения должны СОВПАДАТЬ с solidsimple.ru/public_html/yookassa/.env

# Секрет для переадресации между webhook.php и ботом
# Команда для генерации: openssl rand -hex 16
FORWARD_SECRET=generate_this_with_openssl_rand_hex_16

# Настройки MySQL базы (общая для webhook.php и бота)
YOOKASSA_RELAY_DB_HOST=localhost
YOOKASSA_RELAY_DB_USER=your_mysql_user
YOOKASSA_RELAY_DB_PASS=your_mysql_password
YOOKASSA_RELAY_DB_NAME=your_mysql_database

# Интервал опроса MySQL (секунды). Рекомендуется 5-20.
YOOKASSA_RELAY_POLL_INTERVAL=20

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Тип БД: sqlite или mysql
DATABASE_TYPE=sqlite

# Если DATABASE_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_strong_mysql_password
MYSQL_DATABASE=solid_simple

# Если DATABASE_TYPE=sqlite (для тестов или локальной разработки)
SQLITE_DB_PATH=shop.db

# ===========================================
# BOT MODE (polling или webhook)
# ===========================================
# polling - для локальной разработки
# webhook - для production на сервере
MODE=polling

# Для режима webhook:
WEBHOOK_PORT=8443
WEBHOOK_URL=https://your-domain.com/webhook

# SSL сертификаты (пути к файлам)
# Актуально только для MODE=webhook
SSL_CERT=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ===========================================
# SMTP EMAIL NOTIFICATIONS
# ===========================================
SMTP_HOST=smtp.your-email.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@your-domain.com
ADMIN_EMAIL=admin@your-domain.com

# ===========================================
# GIGACHAT AI ASSISTANT
# ===========================================
# Auth Key из SberDevices
GIGACHAT_AUTH_KEY=your_gigachat_base64_auth_key_from_sberdevices

GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru
GIGACHAT_MODEL=GigaChat
GIGACHAT_SSL_VERIFY=false

# ===========================================
# YANDEX DELIVERY (опционально)
# ===========================================
YANDEX_OTHER_DAY_TOKEN=y0__XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
YANDEX_OTHER_DAY_API_BASE=https://b2b.taxi.yandex.net
SHOP_SOURCE_ADDRESS=Москва, ул. Примерная, д. 1

# ===========================================
# LOGGING AND DEBUG
# ===========================================
# Уровни: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Время жизни сессии (секунды)
SESSION_TTL_SECONDS=1800

# ===========================================
# ADDITIONAL SETTINGS
# ===========================================
# Хост URL для ссылок в админку (опционально)
HOST_URL=https://your-domain.com

# Allowed IP ranges для webhook (опционально, через запятую)
# YooKassa использует эти IP диапазоны:
# YOOKASSA_ALLOWED_IP_RANGES=185.71.76.0/22,185.71.80.0/22

# ===========================================
# SECURITY CHECKLIST
# ===========================================
# Перед запуском проверьте:
# [ ] Все секреты заменены на реальные значения
# [ ] Использованы сложные пароли (16+ символов)
# [ ] .env добавлен в .gitignore
# [ ] Права доступа: chmod 600 .env
# [ ] Тестовые токены заменены на production
# [ ] GigaChat ключ активен
# [ ] MySQL пользователь создан с правильными правами

# ===========================================
# GENERATE NEW SECRETS (команды)
# ===========================================
# YOOKASSA_WEBHOOK_TOKEN:
#   openssl rand -base64 32
#
# FORWARD_SECRET:
#   openssl rand -hex 16
#
# MYSQL_PASSWORD:
#   openssl rand -base64 24
#
# BOT_TOKEN:
#   Получить в @BotFather

# ===========================================
# QUICK START
# ===========================================
# 1. Скопируйте: cp .env.example .env
# 2. Отредактируйте: nano .env
# 3. Замените ВСЕ заглушки на реальные значения
# 4. Проверьте права: chmod 600 .env
# 5. Запустите бота: python main.py
#
# Для проверки конфигурации:
#   python -c "from core.config import validate_config; validate_config()"
